"1781902628244437000","add","CREATE TABLE Territoires (\n    id_territoire INT PRIMARY KEY IDENTITY(1,1),\n    nom_territoire VARCHAR(50) NOT NULL,\n    pays VARCHAR(50) NOT NULL\n);\n\nCREATE TABLE Filiales (\n    id_filiale INT PRIMARY KEY IDENTITY(1,1),\n    nom_filiale VARCHAR(100) NOT NULL,\n    ville VARCHAR(50) NOT NULL,\n    id_territoire INT FOREIGN KEY REFERENCES Territoires(id_territoire)\n);\n\nCREATE TABLE Commerciaux (\n    id_commercial INT PRIMARY KEY IDENTITY(1,1),\n    nom VARCHAR(50) NOT NULL,\n    prenom VARCHAR(50) NOT NULL,\n    id_filiale INT FOREIGN KEY REFERENCES Filiales(id_filiale)\n);\n\nCREATE TABLE Categories_Produit (\n    id_categorie INT PRIMARY KEY IDENTITY(1,1),\n    libelle_categorie VARCHAR(50) NOT NULL\n);\n\nCREATE TABLE Produits (\n    id_produit INT PRIMARY KEY IDENTITY(1,1),\n    code_produit VARCHAR(20) NOT NULL,\n    nom_produit VARCHAR(100) NOT NULL,\n    prix_unitaire DECIMAL(10,2) NOT NULL,\n    id_categorie INT FOREIGN KEY REFERENCES Categories_Produit(id_categorie)\n);\n\nCREATE TABLE Commandes (\n    id_commande INT PRIMARY KEY IDENTITY(1,1),\n    numero_commande VARCHAR(20) NOT NULL,\n    date_commande DATE NOT NULL,\n    id_commercial INT FOREIGN KEY REFERENCES Commerciaux(id_commercial)\n);\n\nCREATE TABLE Lignes_Commande (\n    id_ligne INT PRIMARY KEY IDENTITY(1,1),\n    id_commande INT FOREIGN KEY REFERENCES Commandes(id_commande),\n    id_produit INT FOREIGN KEY REFERENCES Produits(id_produit),\n    quantite INT NOT NULL,\n    prix_facture DECIMAL(10,2) NOT NULL\n);"
